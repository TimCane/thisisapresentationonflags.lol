---
import Base from '@/layouts/Base.astro'
import { getCollection } from 'astro:content'
import { DECK } from '@/lib/deck'

export const prerender = false

const all = await getCollection('flags')
const byCode = new Map(all.map((e) => [e.data.code, e.data]))
const notes = DECK.map((code) => ({
  code,
  name: byCode.get(code)?.name ?? code,
  notes: byCode.get(code)?.notes ?? '',
}))
---

<Base title="Flags - Presenter">
  <main id="app">
    <section id="gate" class="card">
      <h1>Presenter</h1>
      <p class="muted">Enter the room code shown on the screen to take control.</p>
      <input id="code" class="field" placeholder="CODE" maxlength="3" autocapitalize="characters" />
      <button id="unlock" class="primary">Take control</button>
      <p id="gateError" class="error"></p>
    </section>

    <section id="panel" hidden>
      <header class="bar">
        <span>Room <b id="roomCode"></b></span>
        <span id="progress"></span>
        <span><span id="answered">0</span>/<span id="players">0</span></span>
      </header>

      <div id="now" class="card">
        <img id="flag" alt="current flag" />
        <div class="info">
          <p class="label">Answer</p>
          <h2 id="answer">-</h2>
          <p id="notes" class="notes"></p>
        </div>
      </div>

      <div id="controls">
        <button id="reveal" class="primary" hidden>Reveal answer</button>
        <button id="next" class="primary" hidden>Next flag</button>
        <button id="reset" class="ghost">New session</button>
      </div>
    </section>
  </main>

  <style>
    #app {
      max-width: 560px;
      margin: 0 auto;
      padding: 20px;
    }
    .card {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 20px;
    }
    #gate {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-top: 12vh;
    }
    h1 {
      margin: 0;
      font-size: 1.6rem;
    }
    .muted {
      color: var(--muted);
      margin: 0;
    }
    .field {
      padding: 14px;
      font-size: 1.2rem;
      border-radius: 10px;
      border: 1px solid var(--line);
      background: #0e1428;
      color: var(--fg);
      text-transform: uppercase;
      letter-spacing: 0.4em;
      text-align: center;
      font-weight: 700;
    }
    .primary {
      padding: 16px;
      font-size: 1.1rem;
      background: var(--accent);
      border-color: var(--accent);
      font-weight: 700;
    }
    .ghost {
      padding: 14px;
      font-size: 1rem;
      color: var(--muted);
    }
    .error {
      color: var(--bad);
      min-height: 1.2em;
      margin: 0;
    }
    .bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 4px;
      color: var(--muted);
    }
    #now {
      display: flex;
      gap: 16px;
      align-items: flex-start;
      margin-bottom: 16px;
    }
    #flag {
      width: 40%;
      border-radius: 10px;
      border: 1px solid var(--line);
      background: #fff;
    }
    .info {
      flex: 1;
    }
    .label {
      color: var(--muted);
      margin: 0;
      text-transform: uppercase;
      font-size: 0.75rem;
      letter-spacing: 0.1em;
    }
    #answer {
      margin: 2px 0 10px;
      font-size: 1.5rem;
    }
    .notes {
      color: var(--fg);
      line-height: 1.5;
      margin: 0;
    }
    #controls {
      display: grid;
      gap: 10px;
    }
  </style>

  <script>
    import { post, flagUrl, connect } from '@/lib/client'
    import type { Snapshot } from '@/lib/types'

    const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T

    type Note = { code: string; name: string; notes: string }
    const notes = new Map<string, Note>(
      (JSON.parse(document.getElementById('notesData')!.textContent!) as Note[]).map((n) => [
        n.code,
        n,
      ]),
    )

    let snap: Snapshot | null = null
    let code = localStorage.getItem('code') ?? ''
    let unlocked = false
    ;($('code') as HTMLInputElement).value = code

    function tryUnlock(input: string, silent: boolean) {
      if (!snap) return
      if (input.toUpperCase() === snap.code) {
        unlocked = true
        code = snap.code
        localStorage.setItem('code', code)
        $('gate').hidden = true
        $('panel').hidden = false
        render()
      } else if (!silent) {
        $('gateError').textContent = 'That code does not match the live session.'
      }
    }

    $('unlock').addEventListener('click', () =>
      tryUnlock(($('code') as HTMLInputElement).value.trim(), false),
    )

    const control = (action: string) => post('/api/control', { code, action })
    $('next').addEventListener('click', () => control('advance'))
    $('reveal').addEventListener('click', () => control('reveal'))
    $('reset').addEventListener('click', () => {
      if (confirm('Start a new session? Scores reset and the code changes.')) control('reset')
    })

    function render() {
      if (!snap || !unlocked) return
      $('roomCode').textContent = snap.code
      $('progress').textContent =
        snap.phase === 'lobby'
          ? 'Not started'
          : snap.phase === 'ended'
            ? 'Finished'
            : `Flag ${snap.deckIndex + 1} of ${snap.deckSize}`
      const q = snap.question
      $('answered').textContent = String(q?.answered ?? 0)
      $('players').textContent = String(snap.players)

      if (q) {
        ;($('flag') as HTMLImageElement).src = flagUrl(q.flagCode)
        const n = notes.get(q.flagCode)
        $('answer').textContent = n?.name ?? q.flagCode
        $('notes').textContent = n?.notes ?? ''
        $('now').hidden = false
      } else {
        $('now').hidden = true
      }

      $('reveal').hidden = snap.phase !== 'guessing'
      $('next').hidden = snap.phase === 'guessing'
      $('next').textContent = snap.phase === 'lobby' ? 'Start' : 'Next flag'
      ;($('next') as HTMLButtonElement).disabled = snap.phase === 'ended'
    }

    connect((s) => {
      snap = s
      if (!unlocked && code && s.code === code) tryUnlock(code, true)
      if (unlocked && code && s.code !== code) {
        // reset minted a new code; adopt it so controls keep working
        code = s.code
        localStorage.setItem('code', code)
      }
      render()
    })
  </script>

  <script id="notesData" is:inline type="application/json" set:html={JSON.stringify(notes)} />
</Base>
