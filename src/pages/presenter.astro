---
import Base from '@/layouts/Base.astro'
import { getCollection } from 'astro:content'

export const prerender = false

// Slide order must match the runtime builder (sorted by entry id). Embedded so
// the presenter can see the answer + notes without leaking them on the wire.
const slides = await getCollection('slides')
slides.sort((a, b) => a.id.localeCompare(b.id))
const flags = await getCollection('flags')
const nameByCode = new Map(flags.map((e) => [e.data.code, e.data.name]))
const name = (c: string) => nameByCode.get(c) ?? c

const slidesMeta = slides.map((e) => {
  const d = e.data
  if (d.kind === 'guess-flag')
    return { kind: d.kind, notes: d.notes ?? '', answer: name(d.answer), answerCode: d.answer }
  if (d.kind === 'which-flag')
    return {
      kind: d.kind,
      notes: d.notes ?? '',
      prompt: d.prompt ?? `Which flag is ${name(d.answer)}?`,
      answer: name(d.answer),
      answerNumber: d.flags.indexOf(d.answer) + 1,
      flags: d.flags,
    }
  return { kind: d.kind, notes: d.notes ?? '', title: d.title }
})
---

<Base title="Flags - Presenter">
  <main id="app">
    <section id="gate" class="card">
      <h1>Presenter</h1>
      <p class="muted">Enter the room code shown on the screen to take control.</p>
      <input id="code" class="field" placeholder="CODE" maxlength="3" autocapitalize="characters" />
      <button id="unlock" class="primary">Take control</button>
      <p id="gateError" class="error"></p>
    </section>

    <section id="panel" hidden>
      <header class="bar">
        <span>Room <b id="roomCode"></b></span>
        <span id="progress"></span>
        <span><span id="answered">0</span>/<span id="players">0</span></span>
      </header>

      <div id="now" class="card">
        <p class="kicker" id="kind"></p>
        <h2 id="headline">-</h2>
        <div id="thumbs" class="thumbs"></div>
        <p id="notes" class="notes"></p>
      </div>

      <div id="controls">
        <button id="reveal" class="primary" hidden>Reveal answer</button>
        <button id="next" class="primary" hidden>Next</button>
        <button id="reset" class="ghost">New session</button>
      </div>
    </section>
  </main>

  <!-- global: thumbnails are injected by client JS without Astro's scope
       attribute, so scoped styles would not match them. -->
  <style is:global>
    #app {
      max-width: 560px;
      margin: 0 auto;
      padding: 20px;
    }
    .card {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 20px;
    }
    #gate {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-top: 12vh;
    }
    h1 {
      margin: 0;
      font-size: 1.6rem;
    }
    .muted {
      color: var(--muted);
      margin: 0;
    }
    .field {
      padding: 14px;
      font-size: 1.2rem;
      border-radius: 10px;
      border: 1px solid var(--line);
      background: #0e1428;
      color: var(--fg);
      text-transform: uppercase;
      letter-spacing: 0.4em;
      text-align: center;
      font-weight: 700;
    }
    .primary {
      padding: 16px;
      font-size: 1.1rem;
      background: var(--accent);
      border-color: var(--accent);
      font-weight: 700;
    }
    .ghost {
      padding: 14px;
      font-size: 1rem;
      color: var(--muted);
    }
    .error {
      color: var(--bad);
      min-height: 1.2em;
      margin: 0;
    }
    .bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 4px;
      color: var(--muted);
    }
    .kicker {
      color: var(--accent);
      margin: 0;
      text-transform: uppercase;
      font-size: 0.75rem;
      letter-spacing: 0.1em;
    }
    #headline {
      margin: 4px 0 12px;
      font-size: 1.5rem;
    }
    .thumbs {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 12px;
    }
    .thumbs figure {
      margin: 0;
      position: relative;
    }
    .thumbs img {
      height: 56px;
      border-radius: 6px;
      border: 2px solid var(--line);
      background: #fff;
    }
    .thumbs figure.answer img {
      border-color: var(--good);
    }
    .thumbs .n {
      position: absolute;
      top: -6px;
      left: -6px;
      background: var(--accent);
      border-radius: 50%;
      width: 20px;
      height: 20px;
      font-size: 0.75rem;
      display: grid;
      place-items: center;
    }
    .notes {
      line-height: 1.5;
      margin: 0;
    }
    #controls {
      display: grid;
      gap: 10px;
      margin-top: 16px;
    }
  </style>

  <script>
    import { post, flagUrl, connect } from '@/lib/client'
    import type { Snapshot } from '@/lib/types'

    const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T

    type Meta = {
      kind: string
      notes: string
      title?: string
      answer?: string
      answerCode?: string
      answerNumber?: number
      prompt?: string
      flags?: string[]
    }
    const meta = JSON.parse($('slidesData')!.textContent!) as Meta[]

    let snap: Snapshot | null = null
    let code = localStorage.getItem('code') ?? ''
    let unlocked = false
    ;($('code') as HTMLInputElement).value = code

    function tryUnlock(input: string, silent: boolean) {
      if (!snap) return
      if (input.toUpperCase() === snap.code) {
        unlocked = true
        code = snap.code
        localStorage.setItem('code', code)
        $('gate').hidden = true
        $('panel').hidden = false
        render()
      } else if (!silent) {
        $('gateError').textContent = 'That code does not match the live session.'
      }
    }

    $('unlock').addEventListener('click', () =>
      tryUnlock(($('code') as HTMLInputElement).value.trim(), false),
    )

    const control = (action: string) => post('/api/control', { code, action })
    $('next').addEventListener('click', () => control('advance'))
    $('reveal').addEventListener('click', () => control('reveal'))
    $('reset').addEventListener('click', () => {
      if (confirm('Start a new session? Scores reset and the code changes.')) control('reset')
    })

    function render() {
      if (!snap || !unlocked) return
      $('roomCode').textContent = snap.code
      $('progress').textContent =
        snap.phase === 'lobby'
          ? 'Not started'
          : snap.phase === 'ended'
            ? 'Finished'
            : `Slide ${snap.index + 1} of ${snap.total}`

      const slide = snap.slide
      const answered = slide && (slide.kind === 'guess-flag' || slide.kind === 'which-flag')
      $('answered').textContent = String(answered ? slide.answered : 0)
      $('players').textContent = String(snap.players)

      const m: Meta | undefined = snap.index >= 0 ? meta[snap.index] : undefined
      const thumbs = $('thumbs')
      thumbs.innerHTML = ''
      if (!slide || !m) {
        $('kind').textContent = snap.phase === 'ended' ? 'Finished' : 'Lobby'
        $('headline').textContent =
          snap.phase === 'ended' ? 'Final scores are up' : 'Waiting to start'
        $('notes').textContent = ''
      } else if (slide.kind === 'title' || slide.kind === 'section') {
        $('kind').textContent = slide.kind === 'title' ? 'Title' : 'Section'
        $('headline').textContent = m.title ?? ''
        $('notes').textContent = m.notes
      } else if (slide.kind === 'guess-flag') {
        $('kind').textContent = 'What flag is this?'
        $('headline').textContent = `Answer: ${m.answer}`
        thumbs.innerHTML = `<figure class="answer"><img src="${flagUrl(m.answerCode!)}" alt="flag" /></figure>`
        $('notes').textContent = m.notes
      } else {
        $('kind').textContent = 'Which flag is...'
        $('headline').textContent = `${m.prompt} -> #${m.answerNumber} (${m.answer})`
        thumbs.innerHTML = (m.flags ?? [])
          .map(
            (c, i) =>
              `<figure class="${i + 1 === m.answerNumber ? 'answer' : ''}"><span class="n">${i + 1}</span><img src="${flagUrl(c)}" alt="flag" /></figure>`,
          )
          .join('')
        $('notes').textContent = m.notes
      }

      $('reveal').hidden = snap.phase !== 'guessing'
      $('next').hidden = snap.phase === 'guessing'
      $('next').textContent = snap.phase === 'lobby' ? 'Start' : 'Next'
      ;($('next') as HTMLButtonElement).disabled = snap.phase === 'ended'
    }

    connect((s) => {
      snap = s
      if (!unlocked && code && s.code === code) tryUnlock(code, true)
      if (unlocked && code && s.code !== code) {
        code = s.code
        localStorage.setItem('code', code)
      }
      render()
    })
  </script>

  <script id="slidesData" is:inline type="application/json" set:html={JSON.stringify(slidesMeta)} />
</Base>
