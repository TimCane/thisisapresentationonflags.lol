---
import Base from '@/layouts/Base.astro'
import { REACTIONS } from '@/lib/constants'
---

<Base title="Guess the flag">
  <main id="app">
    <section id="gate" class="card">
      <h1>Guess the flag</h1>
      <p class="muted">Enter the code on the big screen to join.</p>
      <input id="code" class="field" placeholder="CODE" maxlength="3" autocapitalize="characters" />
      <input id="nick" class="field" placeholder="Your name" maxlength="24" />
      <button id="join" class="primary">Join</button>
      <p id="gateError" class="error"></p>
    </section>

    <section id="game" hidden>
      <header class="bar">
        <span>Room <b id="roomCode"></b></span>
        <span id="me"></span>
      </header>
      <div id="stage"></div>
      <p id="result"></p>
      <div id="reactions">
        {
          REACTIONS.map((r) => (
            <button class="react" data-key={r.key} aria-label={r.key}>
              {r.emoji}
            </button>
          ))
        }
      </div>
    </section>
  </main>

  <!-- global: stage content is injected by client JS without Astro's scope
       attribute, so scoped styles would not match it. -->
  <style is:global>
    #app {
      max-width: 480px;
      margin: 0 auto;
      padding: 20px 20px 96px;
      min-height: 100%;
    }
    .card {
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding: 24px;
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 16px;
      margin-top: 12vh;
    }
    h1 {
      margin: 0;
      font-size: 1.6rem;
    }
    .muted {
      color: var(--muted);
      margin: 0;
    }
    .field {
      padding: 14px;
      font-size: 1.1rem;
      border-radius: 10px;
      border: 1px solid var(--line);
      background: #0e1428;
      color: var(--fg);
    }
    #code {
      text-transform: uppercase;
      letter-spacing: 0.4em;
      text-align: center;
      font-weight: 700;
    }
    .primary {
      padding: 14px;
      font-size: 1.1rem;
      background: var(--accent);
      border-color: var(--accent);
      font-weight: 700;
    }
    .error {
      color: var(--bad);
      min-height: 1.2em;
      margin: 0;
    }
    .bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 4px;
      color: var(--muted);
    }
    .flagWrap {
      margin: 8px 0 16px;
    }
    .flagWrap img {
      width: 100%;
      border-radius: 10px;
      border: 1px solid var(--line);
      background: #fff;
    }
    .prompt {
      font-size: 1.3rem;
      font-weight: 700;
      text-align: center;
      margin: 12px 0;
    }
    .options,
    .numbers {
      display: grid;
      gap: 10px;
    }
    .numbers {
      grid-template-columns: repeat(auto-fit, minmax(64px, 1fr));
    }
    .opt {
      padding: 16px;
      font-size: 1.1rem;
      text-align: left;
    }
    .num {
      padding: 22px 0;
      font-size: 1.6rem;
      font-weight: 700;
      text-align: center;
    }
    .opt.correct,
    .num.correct {
      background: var(--good);
      border-color: var(--good);
      color: #06210f;
      font-weight: 700;
    }
    .opt.wrong,
    .num.wrong {
      background: var(--bad);
      border-color: var(--bad);
    }
    .opt.mine,
    .num.mine {
      outline: 2px solid var(--accent);
    }
    .info {
      text-align: center;
      margin-top: 8vh;
    }
    .info h2 {
      font-size: 1.6rem;
      margin: 0 0 6px;
    }
    #result {
      min-height: 1.4em;
      font-weight: 700;
      text-align: center;
    }
    #reactions {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      display: flex;
      justify-content: center;
      gap: 8px;
      padding: 12px;
      background: linear-gradient(transparent, var(--bg) 40%);
    }
    .react {
      width: 52px;
      padding: 12px 0;
      font-size: 1.5rem;
      line-height: 1;
    }
  </style>

  <script>
    import { playerId, post, flagUrl, connect } from '@/lib/client'
    import type { Snapshot } from '@/lib/types'

    const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T

    const pid = playerId()
    let snap: Snapshot | null = null
    let joinedCode = localStorage.getItem('code') ?? ''
    let nickname = localStorage.getItem('nick') ?? ''
    let myGuess: { index: number; choice: number } | null = null
    let score = 0
    let lastScored = -1

    ;($('code') as HTMLInputElement).value = joinedCode
    ;($('nick') as HTMLInputElement).value = nickname

    async function doJoin(code: string, nick: string, silent: boolean) {
      const res = await post('/api/join', { code, playerId: pid, nickname: nick })
      if (res.ok) {
        joinedCode = code
        nickname = nick
        localStorage.setItem('code', code)
        localStorage.setItem('nick', nick)
        $('gate').hidden = true
        $('game').hidden = false
        render()
      } else if (!silent) {
        $('gateError').textContent = (res.error as string) ?? 'Could not join'
      }
    }

    $('join').addEventListener('click', () => {
      const code = ($('code') as HTMLInputElement).value.trim().toUpperCase()
      const nick = ($('nick') as HTMLInputElement).value.trim()
      if (code.length !== 3 || !nick) {
        $('gateError').textContent = 'Enter the 3-letter code and a name.'
        return
      }
      doJoin(code, nick, false)
    })

    for (const btn of document.querySelectorAll<HTMLButtonElement>('.react')) {
      btn.addEventListener('click', () => {
        if (!joinedCode) return
        post('/api/react', { code: joinedCode, playerId: pid, reaction: btn.dataset.key })
      })
    }

    function guess(choice: number) {
      if (!snap || snap.phase !== 'guessing' || !snap.slide) return
      if (myGuess && myGuess.index === snap.index) return
      myGuess = { index: snap.index, choice }
      post('/api/guess', { code: joinedCode, playerId: pid, optionIndex: choice })
      render()
    }

    function makeButton(
      cls: string,
      label: string,
      i: number,
      enabled: boolean,
    ): HTMLButtonElement {
      const b = document.createElement('button')
      b.className = cls
      b.textContent = label
      if (enabled) b.addEventListener('click', () => guess(i))
      else b.disabled = true
      return b
    }

    function decorate(b: HTMLButtonElement, i: number, correctIndex: number, revealed: boolean) {
      const answered = !!myGuess && myGuess.index === snap!.index
      if (answered && myGuess!.choice === i) b.classList.add('mine')
      if (revealed) {
        if (i === correctIndex) b.classList.add('correct')
        else if (answered && myGuess!.choice === i) b.classList.add('wrong')
      }
    }

    function render() {
      if (!snap) return
      $('roomCode').textContent = snap.code
      $('me').textContent = `${nickname} - ${score} pts`
      const stage = $('stage')
      const result = $('result')
      stage.innerHTML = ''
      result.textContent = ''

      const slide = snap.slide
      if (snap.phase === 'lobby' || !slide) {
        stage.innerHTML = `<div class="info"><p class="muted">${
          snap.phase === 'ended' ? "That's a wrap - thanks for playing!" : 'Waiting to start...'
        }</p></div>`
        return
      }

      if (slide.kind === 'title' || slide.kind === 'section') {
        const sub = slide.subtitle ? `<p class="muted">${slide.subtitle}</p>` : ''
        stage.innerHTML = `<div class="info"><h2>${slide.title}</h2>${sub}<p class="muted">Eyes on the big screen.</p></div>`
        return
      }

      const revealed = snap.phase === 'revealed'
      const answered = !!myGuess && myGuess.index === snap.index
      const correctIndex = slide.answerIndex ?? -1

      if (slide.kind === 'guess-flag') {
        const wrap = document.createElement('div')
        wrap.className = 'flagWrap'
        wrap.innerHTML = `<img alt="flag" src="${flagUrl(slide.flagCode)}" />`
        stage.appendChild(wrap)
        const box = document.createElement('div')
        box.className = 'options'
        slide.options.forEach((o, i) => {
          const b = makeButton('opt', o.name, i, !revealed && !answered)
          decorate(b, i, correctIndex, revealed)
          box.appendChild(b)
        })
        stage.appendChild(box)
      } else {
        const p = document.createElement('p')
        p.className = 'prompt'
        p.textContent = slide.prompt
        stage.appendChild(p)
        const box = document.createElement('div')
        box.className = 'numbers'
        slide.flags.forEach((_, i) => {
          const b = makeButton('num', String(i + 1), i, !revealed && !answered)
          decorate(b, i, correctIndex, revealed)
          box.appendChild(b)
        })
        stage.appendChild(box)
      }

      if (revealed) {
        const right = answered && myGuess!.choice === correctIndex
        if (answered && right && lastScored !== snap.index) {
          score += 1
          lastScored = snap.index
          $('me').textContent = `${nickname} - ${score} pts`
        }
        result.textContent = !answered ? '' : right ? 'Correct! +1' : 'Not quite.'
      } else {
        result.textContent = answered ? 'Locked in. Hold tight...' : ''
      }
    }

    connect((s) => {
      if (joinedCode && s.code !== joinedCode && !$('game').hidden) {
        joinedCode = ''
        myGuess = null
        score = 0
        lastScored = -1
        $('game').hidden = true
        $('gate').hidden = false
        $('gateError').textContent = 'New session started - enter the new code.'
      }
      if (snap && myGuess && s.index !== snap.index) myGuess = null
      snap = s
      if ($('game').hidden && joinedCode && nickname && s.code === joinedCode) {
        doJoin(joinedCode, nickname, true)
      }
      if (!$('game').hidden) render()
    })
  </script>
</Base>
