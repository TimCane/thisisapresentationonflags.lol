---
import Base from '@/layouts/Base.astro'
import { ensureSession, snapshot } from '@/lib/session'

export const prerender = false

// Loading the projector view mints the session so its code is on screen before
// anyone connects.
ensureSession()
const initial = snapshot()
---

<Base title="Flags - Display">
  <main id="screen" data-initial={JSON.stringify(initial)}>
    <div class="hud">
      <div id="meta" class="muted"></div>
      <div class="badge">code <b id="badgeCode">{initial.code}</b></div>
    </div>

    <section id="stage"></section>

    <aside id="leaderboard" hidden>
      <h2>Leaders</h2>
      <ol id="board" class="board"></ol>
    </aside>

    <div id="reactions" aria-hidden="true"></div>
  </main>

  <style>
    #screen {
      height: 100%;
      display: flex;
      flex-direction: column;
      padding: 2vmin 3vmin;
      position: relative;
      overflow: hidden;
    }
    .hud {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 2.2vmin;
    }
    .muted {
      color: var(--muted);
    }
    .badge {
      color: var(--muted);
    }
    .code {
      color: var(--accent);
      letter-spacing: 0.15em;
    }
    .badge b {
      color: var(--accent);
      letter-spacing: 0.15em;
    }
    #stage {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
    }
    .bigcard h1 {
      font-size: 8vmin;
      margin: 0 0 2vmin;
      line-height: 1.05;
    }
    .bigcard .sub {
      font-size: 3.4vmin;
      color: var(--muted);
      margin: 0;
    }
    .kicker {
      text-transform: uppercase;
      letter-spacing: 0.3em;
      color: var(--accent);
      font-size: 2.4vmin;
      margin: 0 0 1vmin;
    }
    .joinbig {
      font-size: 4vmin;
      margin-top: 4vmin;
    }
    .round {
      display: flex;
      gap: 4vmin;
      align-items: center;
      width: 100%;
      justify-content: center;
    }
    .flag {
      width: 46vw;
      max-height: 64vh;
      border-radius: 1.5vmin;
      border: 1px solid var(--line);
      background: #fff;
      box-shadow: 0 1vmin 4vmin rgba(0, 0, 0, 0.4);
    }
    .opts {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 1.6vmin;
      width: 38vw;
      text-align: left;
    }
    .opt {
      position: relative;
      padding: 2.4vmin;
      border-radius: 1.2vmin;
      background: var(--panel);
      border: 1px solid var(--line);
      font-size: 3vmin;
      overflow: hidden;
    }
    .opt .fill {
      position: absolute;
      inset: 0;
      background: rgba(79, 124, 255, 0.25);
      width: 0;
      transition: width 0.4s ease;
    }
    .opt .label,
    .opt .count {
      position: relative;
    }
    .opt .count {
      float: right;
      color: var(--muted);
    }
    .opt.correct {
      border-color: var(--good);
    }
    .opt.correct .fill {
      background: rgba(46, 204, 113, 0.35);
    }
    .which .prompt {
      font-size: 4.5vmin;
      margin: 0 0 3vmin;
    }
    .flags {
      display: flex;
      gap: 3vmin;
      justify-content: center;
      align-items: flex-end;
      flex-wrap: wrap;
    }
    .fcard {
      margin: 0;
      position: relative;
    }
    .fcard img {
      width: 26vw;
      max-height: 36vh;
      border-radius: 1vmin;
      border: 2px solid var(--line);
      background: #fff;
    }
    .fcard.correct img {
      border-color: var(--good);
      box-shadow: 0 0 3vmin rgba(46, 204, 113, 0.6);
    }
    .numbadge {
      position: absolute;
      top: -2vmin;
      left: -2vmin;
      width: 6vmin;
      height: 6vmin;
      border-radius: 50%;
      background: var(--accent);
      display: grid;
      place-items: center;
      font-size: 3vmin;
      font-weight: 700;
    }
    .fcount {
      display: block;
      margin-top: 1vmin;
      font-size: 2.6vmin;
      color: var(--muted);
    }
    #leaderboard {
      position: absolute;
      right: 3vmin;
      bottom: 3vmin;
      width: 26vw;
      background: rgba(10, 14, 30, 0.9);
      border: 1px solid var(--line);
      border-radius: 1.5vmin;
      padding: 2vmin;
    }
    #leaderboard h2 {
      margin: 0 0 1vmin;
      font-size: 2.6vmin;
    }
    .board {
      margin: 0;
      padding-left: 4vmin;
      font-size: 2.6vmin;
    }
    .board li {
      margin: 0.6vmin 0;
    }
    .board .pts {
      float: right;
      color: var(--accent);
      font-weight: 700;
    }
    #reactions {
      position: fixed;
      inset: 0;
      pointer-events: none;
      overflow: hidden;
    }
    .floater {
      position: fixed;
      bottom: 1vh;
      font-size: 5vmin;
      will-change: transform, opacity;
      animation: rise 2.6s ease-out forwards;
    }
    @keyframes rise {
      0% {
        transform: translateY(0) scale(0.6);
        opacity: 0;
      }
      12% {
        opacity: 1;
      }
      100% {
        transform: translateY(-82vh) scale(1.25);
        opacity: 0;
      }
    }
  </style>

  <script>
    import { connect, flagUrl } from '@/lib/client'
    import type { Snapshot } from '@/lib/types'

    const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T

    function escapeHtml(s: string): string {
      return s.replace(
        /[&<>"]/g,
        (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' })[c] ?? c,
      )
    }

    function lobby(code: string): string {
      return `<div class="bigcard"><h1>thisisapresentationonflags<span class="muted">.lol</span></h1>
        <p class="joinbig">Use code <b class="code">${code}</b> to join</p>
        <p class="sub">Grab your phone.</p></div>`
    }

    function quizOptions(slide: Extract<Snapshot['slide'], { kind: 'guess-flag' }>): string {
      const total = slide.tally.reduce((a, b) => a + b, 0)
      const items = slide.options
        .map((o, i) => {
          const pct = total ? Math.round((slide.tally[i] / total) * 100) : 0
          const correct = slide.answerIndex === i ? ' correct' : ''
          return `<li class="opt${correct}"><span class="fill" style="width:${pct}%"></span>
            <span class="count">${slide.tally[i]}</span><span class="label">${escapeHtml(o.name)}</span></li>`
        })
        .join('')
      return `<div class="round"><img class="flag" src="${flagUrl(slide.flagCode)}" alt="flag" />
        <ul class="opts">${items}</ul></div>`
    }

    function whichFlags(slide: Extract<Snapshot['slide'], { kind: 'which-flag' }>): string {
      const cards = slide.flags
        .map((c, i) => {
          const correct = slide.answerIndex === i ? ' correct' : ''
          return `<figure class="fcard${correct}"><span class="numbadge">${i + 1}</span>
            <img src="${flagUrl(c)}" alt="flag ${i + 1}" />
            <span class="fcount">${slide.tally[i]}</span></figure>`
        })
        .join('')
      return `<div class="which"><h2 class="prompt">${escapeHtml(slide.prompt)}</h2>
        <div class="flags">${cards}</div></div>`
    }

    function board(rows: Snapshot['leaderboard']): string {
      return rows
        .map((r) => `<li><span class="pts">${r.score}</span>${escapeHtml(r.nickname)}</li>`)
        .join('')
    }

    function render(s: Snapshot) {
      $('badgeCode').textContent = s.code
      const slide = s.slide
      const answered = slide && (slide.kind === 'guess-flag' || slide.kind === 'which-flag')
      $('meta').textContent = answered
        ? `${s.players} playing - ${slide.answered} answered`
        : `${s.players} playing`

      const stage = $('stage')
      if (!slide || s.phase === 'lobby') {
        stage.innerHTML =
          s.phase === 'ended'
            ? `<div class="bigcard"><p class="kicker">Final scores</p><ol class="board">${board(s.leaderboard)}</ol></div>`
            : lobby(s.code)
      } else if (slide.kind === 'title') {
        const sub = slide.subtitle ? `<p class="sub">${escapeHtml(slide.subtitle)}</p>` : ''
        const join = slide.showCode
          ? `<p class="joinbig">Use code <b class="code">${s.code}</b> to join</p>`
          : ''
        stage.innerHTML = `<div class="bigcard"><h1>${escapeHtml(slide.title)}</h1>${sub}${join}</div>`
      } else if (slide.kind === 'section') {
        const sub = slide.subtitle ? `<p class="sub">${escapeHtml(slide.subtitle)}</p>` : ''
        stage.innerHTML = `<div class="bigcard"><p class="kicker">Section</p><h1>${escapeHtml(slide.title)}</h1>${sub}</div>`
      } else if (slide.kind === 'guess-flag') {
        stage.innerHTML = quizOptions(slide)
      } else {
        stage.innerHTML = whichFlags(slide)
      }

      const showBoard = s.phase === 'revealed' && s.leaderboard.length > 0
      $('leaderboard').hidden = !showBoard
      if (showBoard) $('board').innerHTML = board(s.leaderboard)
    }

    function floatReaction(emoji: string) {
      const span = document.createElement('span')
      span.className = 'floater'
      span.textContent = emoji
      span.style.left = 6 + Math.random() * 88 + 'vw'
      $('reactions').appendChild(span)
      setTimeout(() => span.remove(), 2700)
    }

    const initial = JSON.parse($('screen').dataset.initial!) as Snapshot
    render(initial)
    connect(render, floatReaction)
  </script>
</Base>
